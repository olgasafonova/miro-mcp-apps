{
  "name": "miro-mcp-apps",
  "version": "0.1.0",
  "description": "MCP Apps pilot for Miro — interactive UI tools (board summary card, list items table) returning rendered cards instead of JSON. Companion to the Go miro-mcp-server.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:ui:summary": "cross-env INPUT=board-summary.html vite build",
    "build:ui:list": "cross-env INPUT=list-items.html vite build",
    "build:ui:frames": "cross-env INPUT=frame-overview.html vite build",
    "build:ui:stickies": "cross-env INPUT=sticky-clusters.html vite build",
    "build:ui:recent": "cross-env INPUT=recent-boards.html vite build",
    "build:ui:connectors": "cross-env INPUT=connectors.html vite build",
    "build:ui": "npm run build:ui:summary && npm run build:ui:list && npm run build:ui:frames && npm run build:ui:stickies && npm run build:ui:recent && npm run build:ui:connectors",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "tsc --noEmit && npm run build:ui && npm run build:server",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio",
    "dev:stdio": "tsx main.ts --stdio",
    "dev": "tsx watch main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
